{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Debug",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "UploadSettings": {
    "ChunkSize": 5242880,
    "MaxFileSize": 10737418240,
    "UploadPath": "workspace/uploads",
    "StagingPath": "workspace/staging",
    "TempFileRetentionDays": 7,
    "MaxConcurrentUploads": 5,
    "AllowedExtensions": [".mp4", ".mkv", ".avi", ".mov", ".wmv", ".flv", ".webm"]
  },
  "PluginSettings": {
    "PluginPath": "workspace/plugins",
    "EnabledPlugins": []
  }
}
