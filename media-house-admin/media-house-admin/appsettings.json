{ 
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:5000"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "Path": "mediahouse.db"
  },
  "Media": {
    "MediaRootPath": ""
  },
  "Scan": {
    "IncrementalIntervalMinutes": 15,
    "ConsistencyCheckIntervalHours": 24
  },
  "Jwt": {
    "Secret": "your-very-long-secret-key-at-least-32-characters-long-for-hmac-sha256",
    "Issuer": "MediaHouse",
    "Audience": "MediaHouse",
    "ExpirationMinutes": 1440
  },
  "UploadSettings": {
    "ChunkSize": 5242880,
    "MaxFileSize": 10737418240,
    "UploadPath": "/app/workspace/uploads",
    "StagingPath": "/app/workspace/staging",
    "TempFileRetentionDays": 7,
    "MaxConcurrentUploads": 5,
    "AllowedExtensions": [".mp4", ".mkv", ".avi", ".mov", ".wmv", ".flv", ".webm"]
  },
  "PluginSettings": {
    "PluginPath": "/app/workspace/plugins",
    "EnabledPlugins": []
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "SQLite",
        "Args": {
          "sqliteDbPath": "mediahouse.db",
          "tableName": "system_logs",
          "restrictedToMinimumLevel": "Information"
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"],
    "Properties": {
      "Application": "MediaHouse"
    }
  }
}
