{ 
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:5000"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=mediahouse.db",
    "LoggerConnection": "Data Source=mediahouse-logs.db"
  },
  "Database": {
    "Provider": "Sqlite",
    "DefaultConnection": "Data Source=mediahouse.db",
    "Logger": "Data Source=mediahouse-logs.db",
    "MySql": {
      "DefaultConnection": "Server=localhost;Port=3308;Database=mediahouse;User=root;Password=xfssgmwqy;",
      "Logger": "Server=localhost;Port=3308;Database=mediahouse_logs;User=root;Password=xfssgmwqy;"
    }
  },
  "Media": {
    "MediaRootPath": ""
  },
  "Scan": {
    "IncrementalIntervalMinutes": 15,
    "ConsistencyCheckIntervalHours": 24
  },
  "Jwt": {
    "Secret": "your-very-long-secret-key-at-least-32-characters-long-for-hmac-sha256",
    "Issuer": "MediaHouse",
    "Audience": "MediaHouse",
    "ExpirationMinutes": 1440
  },
  "UploadSettings": {
    "ChunkSize": 5242880,
    "MaxFileSize": 10737418240,
    "UploadPath": "/app/workspace/uploads",
    "StagingPath": "/app/workspace/staging",
    "TempFileRetentionDays": 7,
    "MaxConcurrentUploads": 5,
    "AllowedExtensions": [".mp4", ".mkv", ".avi", ".mov", ".wmv", ".flv", ".webm"]
  },
  "PluginSettings": {
    "PluginPath": "/app/workspace/plugins",
    "EnabledPlugins": []
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
